{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "EventLog",
        "Args": {
          "source": "HomeEconomics",
          "manageEventSource": true
        }
      }
    ]
  }
}